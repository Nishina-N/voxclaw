# Environment / Secrets
.env
keybinder/secrets/*
!keybinder/secrets/.gitkeep
!keybinder/secrets/keys.example.json

# User-specific runtime config (may contain personal data)
config/channels.json

# Dependencies
node_modules/

# Runtime data (mounted volumes - not part of source code)
memory/
workspace/
knowledge/
media/

# pip packages installed at runtime (platform-specific, can be large)
config/pip_packages/

# TypeScript build output
dist/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Claude Code worktrees
.claude/worktrees/
