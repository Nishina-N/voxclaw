# --- Discord ---（Discordをインターフェースとして使う場合）
DISCORD_TOKEN=
TALK_CHANNEL_ID=    # メンションなしで応答するチャンネルのID

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# --- PWA認証 ---
PWA_PASSWORD=123456  # 初回起動前に変更推奨

# --- Cloudflare Tunnel ---（ドメインを使って外部からアクセス可能にする場合）
# docker compose --profile tunnel up -d で有効化
CLOUDFLARE_TUNNEL_TOKEN=
