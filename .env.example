# --- Discord ---（Discordをインターフェースとして使う場合）
DISCORD_TOKEN=
TALK_CHANNEL_ID=    # メンションなしで応答するチャンネルのID

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
VOICE_GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025  # voice-pwa用（音声対応モデル）

# --- PWA認証 ---
PWA_PASSWORD=123456   # 初回起動前に変更推奨
JWT_SECRET=           # 未設定の場合はPWA_PASSWORDが使われる（任意の長い文字列を推奨）

# --- Google OAuth ---（Googleサービスを使う場合）
# keybinder/secrets/client_secret.json を配置した上で、チャットで「Googleの認証をセットアップして」と話しかける
# Cloudflare Tunnel等を使う場合はリダイレクト先URLを変更し、Google Cloud Consoleにも登録する
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000

# --- Cloudflare Tunnel ---（ドメインを使って外部からアクセス可能にする場合）
# docker compose --profile tunnel up -d で有効化
CLOUDFLARE_TUNNEL_TOKEN=
